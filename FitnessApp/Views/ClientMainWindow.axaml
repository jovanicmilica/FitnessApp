<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FitnessApp.ViewModels"
        xmlns:converters="clr-namespace:FitnessApp.Converters"
        x:Class="FitnessApp.Views.ClientMainWindow"
        x:DataType="vm:ClientMainViewModel"
        Title="Fitness Mentoring — Client"
        Width="1000" Height="800"
        MinWidth="900" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Background="#F5F5F5">

    <Window.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <converters:IsNotNullOrEmptyConverter x:Key="StringIsNotNullOrEmpty"/>
        <converters:RatingToStarsConverter x:Key="RatingToStarsConverter"/>
        <converters:IsGreaterThanZeroConverter x:Key="IsGreaterThanZeroConverter"/>
    </Window.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Margin="24">

        <!-- Header - red 0 -->
        <DockPanel Grid.Row="0" Margin="0 0 0 12">
            <TextBlock Text="Welcome!"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="#2C3E50"/>
            <Button Content="Logout"
                    Command="{Binding LogoutCommand}"
                    HorizontalAlignment="Right"
                    Padding="20,8"
                    Background="#4EBF7E"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Cursor="Hand"/>
        </DockPanel>

        <!-- Status/Error poruke - red 1 -->
        <StackPanel Grid.Row="1" Margin="0 0 0 8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#27AE60"
                       FontWeight="SemiBold"
                       IsVisible="{Binding StatusMessage, Converter={StaticResource StringIsNotNullOrEmpty}}"/>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#E74C3C"
                       FontWeight="SemiBold"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringIsNotNullOrEmpty}}"/>
        </StackPanel>

        <!-- TabControl - red 2 -->
        <TabControl Grid.Row="2" Background="White">

            <!-- TAB 1: Search Trainers -->
            <TabItem Header="Search Trainers">
                <Grid ColumnDefinitions="*,*" Margin="16">

                    <StackPanel Grid.Column="0" Margin="0 0 16 0" Spacing="10">
                        <TextBlock Text="Find Your Trainer"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"/>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{Binding SearchCriteria}"
                                     PlaceholderText="Search by name..."
                                     Padding="10"
                                     Height="38"
                                     Width="200"
                                     FontSize="13"/>
                            <Button Content="Search"
                                    Command="{Binding SearchTrainersCommand}"
                                    Padding="20,8"
                                    Background="#5BA3D0"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"/>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="350">
                            <ListBox ItemsSource="{Binding AvailableTrainers}"
                                     SelectedItem="{Binding SelectedTrainer}"
                                     Padding="6">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10" Background="#F9F9F9" CornerRadius="4" Margin="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontWeight="Bold" Foreground="#2C3E50" FontSize="14">
                                                    <Run Text="{Binding FirstName}"/>
                                                    <Run Text="{Binding LastName}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding PricePerMonth, StringFormat='${0:F2}/month'}"
                                                           FontSize="11"
                                                           Foreground="#555555"/>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding Rating, Converter={StaticResource RatingToStarsConverter}}"
                                                               FontSize="13"
                                                               Foreground="#F39C12"/>
                                                    <TextBlock Text="{Binding Rating, StringFormat='({0:F1})'}"
                                                               FontSize="10"
                                                               Foreground="#888888"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>

                        <Button Content="View Trainer Feedbacks"
                                Command="{Binding ViewTrainerFeedbacksCommand}"
                                Padding="20,8"
                                Background="#A966D3"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Cursor="Hand"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="16 0 0 0" Spacing="10">
                        <TextBlock Text="Send Request"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"/>

                        <TextBlock Text="Your Goals"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                        <TextBox Text="{Binding Goals}"
                                 PlaceholderText="e.g. Lose weight, build muscle..."
                                 Height="60"
                                 Padding="10"
                                 FontSize="12"
                                 AcceptsReturn="True"/>

                        <TextBlock Text="Location Preference"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                        <TextBox Text="{Binding LocationPreference}"
                                 PlaceholderText="e.g. Gym, Home, Outdoor"
                                 Padding="10"
                                 Height="36"
                                 FontSize="12"/>

                        <TextBlock Text="Time Preference"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                        <TextBox Text="{Binding TimePreference}"
                                 PlaceholderText="e.g. Mornings, Weekends"
                                 Padding="10"
                                 Height="36"
                                 FontSize="12"/>

                        <TextBlock Text="Health Issues (optional)"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                        <TextBox Text="{Binding HealthIssues}"
                                 PlaceholderText="e.g. Bad knee, asthma..."
                                 Height="60"
                                 Padding="10"
                                 FontSize="12"
                                 AcceptsReturn="True"/>

                        <Button Content="Send Request"
                                Command="{Binding SendTutelageRequestCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="20,10"
                                Background="#4EBF7E"
                                Foreground="White"
                                FontWeight="SemiBold"
                                FontSize="14"
                                Cursor="Hand"/>
                    </StackPanel>

                </Grid>
            </TabItem>

            <!-- TAB 2: My Tutelages -->
            <TabItem Header="My Tutelages">
                <Grid ColumnDefinitions="*,*" Margin="16">

                    <StackPanel Grid.Column="0" Margin="0 0 16 0" Spacing="10">
                        <TextBlock Text="My Tutelages"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="400">
                            <ListBox ItemsSource="{Binding MyTutelages}"
                                     SelectedItem="{Binding SelectedTutelage}"
                                     Padding="6">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10" Background="#F9F9F9" CornerRadius="4" Margin="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontWeight="Bold" Foreground="#2C3E50" FontSize="13">
                                                    <Run Text="{Binding Status, StringFormat='Status: {0}'}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding StartDate, StringFormat='Start: {0:dd/MM/yyyy}'}"
                                                           FontSize="11"
                                                           Foreground="#555555"/>
                                                <TextBlock Text="{Binding EndDate, StringFormat='End: {0:dd/MM/yyyy}'}"
                                                           FontSize="11"
                                                           Foreground="#555555"/>
                                                <TextBlock Text="{Binding TrainerId, StringFormat='Trainer ID: {0}'}"
                                                           FontSize="10"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>

                        <Button Content="Pay for Tutelage"
                                Command="{Binding PayForTutelageCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="20,8"
                                Background="#FFA04D"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Cursor="Hand"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="16 0 0 0" Spacing="10">
                        <TextBlock Text="Rate Your Trainer"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"/>
                        
                        <TextBlock Text="Leave feedback for your trainer"
                                   FontSize="12"
                                   Foreground="#888888"
                                   Margin="0,-4,0,0"/>

                        <Border Height="1" Background="#E0E0E0"/>

                        <TextBlock Text="Rating (1-5)"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                        <NumericUpDown Value="{Binding FeedbackRating}"
                                       Minimum="1"
                                       Maximum="5"
                                       Increment="1"
                                       Padding="10"
                                       Height="38"
                                       FontSize="13"/>

                        <TextBlock Text="Comment"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                        <TextBox Text="{Binding FeedbackComment}"
                                 PlaceholderText="Share your experience with this trainer..."
                                 Height="100"
                                 Padding="10"
                                 FontSize="12"
                                 AcceptsReturn="True"/>

                        <Button Content="Submit Trainer Feedback"
                                Command="{Binding LeaveFeedbackCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="20,10"
                                Background="#A966D3"
                                Foreground="White"
                                FontWeight="SemiBold"
                                FontSize="14"
                                Cursor="Hand"/>
                        
                        <TextBlock Text="💡 Select a tutelage first, then rate your trainer"
                                   FontSize="11"
                                   Foreground="#888888"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                </Grid>
            </TabItem>

            <!-- TAB 3: My Workouts -->
<TabItem Header="My Workouts">
    <Grid ColumnDefinitions="*,*" Margin="16">

        <StackPanel Grid.Column="0" Margin="0 0 16 0" Spacing="10">
            <TextBlock Text="My Workouts"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#2C3E50"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="350">
                <ListBox ItemsSource="{Binding MyWorkouts}"
                         SelectedItem="{Binding SelectedWorkout}"
                         Padding="6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Background="#F9F9F9" CornerRadius="4" Margin="6">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Foreground="#2C3E50"/>
                                    <TextBlock Text="{Binding Status, StringFormat='Status: {0}'}"
                                               FontSize="11"
                                               Foreground="#555555"/>
                                    <TextBlock Text="{Binding DateCreated, StringFormat='Created: {0:dd/MM/yyyy}'}"
                                               FontSize="10"
                                               Foreground="#888888"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <Button Content="View Details"
                    Command="{Binding ViewWorkoutDetailsCommand}"
                    HorizontalAlignment="Stretch"
                    Padding="20,8"
                    Background="#5BA3D0"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Cursor="Hand"/>

            <Button Content="Show/Hide Exercise Ratings"
                    Command="{Binding ShowExerciseFeedbackForWorkoutCommand}"
                    HorizontalAlignment="Stretch"
                    Padding="20,8"
                    Background="#5BA3D0"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Cursor="Hand"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="16 0 0 0" Spacing="8">
            <TextBlock Text="Workout Details"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#2C3E50"/>

            <Border Background="#F9F9F9" 
                    CornerRadius="4" 
                    Padding="12"
                    Height="140">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding SelectedWorkoutDetails}"
                                   TextWrapping="Wrap"
                                   Foreground="#555555"
                                   FontSize="12"/>
                        
                        <TextBlock Text="Exercises:"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"
                                   Margin="0,4,0,0"
                                   FontSize="12"/>
                        
                        <ItemsControl ItemsSource="{Binding SelectedWorkoutExercises}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" 
                                            CornerRadius="4" 
                                            Padding="6,2" 
                                            Margin="0,1">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding ExerciseName}"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="#2C3E50"/>
                                            <TextBlock Text="{Binding Sets, StringFormat='Sets: {0}'}"
                                                       FontSize="10"
                                                       Foreground="#555555"/>
                                            <TextBlock Text="{Binding Repetitions, StringFormat='Reps: {0}'}"
                                                       FontSize="10"
                                                       Foreground="#555555"/>
                                            <TextBlock Text="{Binding DurationInSeconds, StringFormat='Duration: {0}s'}"
                                                       FontSize="10"
                                                       Foreground="#555555"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Workout Feedback - sa skrolom -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled"
                          Height="370">
                
                <StackPanel Spacing="6">
                    
                    <TextBlock Text="⭐ Rate This Workout"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#2C3E50"/>

                    <TextBlock Text="Rating (1-5)"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#333333"/>
                    <NumericUpDown Value="{Binding WorkoutFeedbackRating}"
                                   Minimum="1"
                                   Maximum="5"
                                   Increment="1"
                                   Padding="10"
                                   Height="35"/>

                    <TextBlock Text="Comment"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#333333"/>
                    <TextBox Text="{Binding WorkoutFeedbackComment}"
                             PlaceholderText="How was this workout?"
                             Height="50"
                             Padding="10"
                             AcceptsReturn="True"/>

                    <Button Content="Submit Workout Feedback"
                            Command="{Binding LeaveWorkoutFeedbackCommand}"
                            HorizontalAlignment="Stretch"
                            Padding="20,8"
                            Background="#A966D3"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Cursor="Hand"/>

                    <!-- Exercise Feedback -->
                    <StackPanel IsVisible="{Binding IsExerciseFeedbackVisible}" Spacing="6">
                        
                        <Border Height="1" Background="#E0E0E0" Margin="0,4,0,4"/>

                        <TextBlock Text="🏋️ Rate Individual Exercise"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"/>

                        <TextBlock Text="Select Exercise"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                        
                        <ComboBox ItemsSource="{Binding WorkoutExercisesForFeedback}"
                                  SelectedItem="{Binding SelectedExercise}"
                                  Padding="8"
                                  Height="35">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Rating (1-5)"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                        <NumericUpDown Value="{Binding ExerciseFeedbackRating}"
                                       Minimum="1"
                                       Maximum="5"
                                       Increment="1"
                                       Padding="10"
                                       Height="35"/>

                        <TextBlock Text="Comment"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#333333"/>
                        <TextBox Text="{Binding ExerciseFeedbackComment}"
                                 PlaceholderText="How was this exercise?"
                                 Height="50"
                                 Padding="10"
                                 AcceptsReturn="True"/>

                        <TextBlock Text="{Binding ExerciseFeedbackMessage}"
                                   Foreground="#27AE60"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   IsVisible="{Binding ExerciseFeedbackMessage, 
                                       Converter={StaticResource StringIsNotNullOrEmpty}}"/>

                        <Button Content="Submit Exercise Feedback"
                                Command="{Binding LeaveExerciseFeedbackCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="20,8"
                                Background="#E67E22"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Cursor="Hand"/>
                    </StackPanel>
                    
                </StackPanel>
            </ScrollViewer>

        </StackPanel>

    </Grid>
</TabItem>

<!-- TAB 4: My Feedbacks -->
<TabItem Header="My Feedbacks">
    <StackPanel Margin="16" Spacing="12">
        <TextBlock Text="My Feedbacks"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#2C3E50"/>

        <TextBlock Text="Feedbacks you have given"
                   FontSize="12"
                   Foreground="#888888"/>

        <Border Height="1" Background="#E0E0E0"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="500">
            <ItemsControl ItemsSource="{Binding MyFeedbacks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#F9F9F9" 
                                CornerRadius="4" 
                                Padding="12" 
                                Margin="0,4">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding TargetType}"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               Foreground="#2C3E50"/>
                                    <TextBlock Text="{Binding TargetName}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="#2C3E50"/>
                                    <TextBlock Text="{Binding Rating, StringFormat='⭐ {0}/5'}"
                                               FontSize="13"
                                               Foreground="#F39C12"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Comment}"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Foreground="#555555"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </StackPanel>
</TabItem>
            <!-- TAB 5: Profile -->
            <TabItem Header="Profile">
                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled">
                    
                    <ContentControl Content="{Binding ProfileViewModel}">
                        <ContentControl.DataTemplates>
                            <DataTemplate DataType="{x:Type vm:ClientProfileViewModel}">
                                
                                <StackPanel Margin="24" Spacing="16">
                                    
                                    <TextBlock Text="Profile Settings"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="#2C3E50"/>
                                    
                                    <TextBlock Text="Manage your personal information"
                                               FontSize="13"
                                               Foreground="#888888"
                                               Margin="0,-8,0,0"/>
                                    
                                    <Border Height="1" Background="#E0E0E0"/>
                                    
                                    <Grid IsVisible="{Binding IsLoading}">
                                        <TextBlock Text="Saving..." Foreground="#3498DB" FontWeight="SemiBold"/>
                                    </Grid>
                                    
                                    <Grid IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                                        <StackPanel Spacing="12">
                                            
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="First Name" FontWeight="SemiBold" Foreground="#333"/>
                                                <TextBox Text="{Binding FirstName}"
                                                         IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}"
                                                         PlaceholderText="Enter first name"
                                                         Padding="12"
                                                         Height="40"/>
                                            </StackPanel>
                                            
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Last Name" FontWeight="SemiBold" Foreground="#333"/>
                                                <TextBox Text="{Binding LastName}"
                                                         IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}"
                                                         PlaceholderText="Enter last name"
                                                         Padding="12"
                                                         Height="40"/>
                                            </StackPanel>
                                            
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Email" FontWeight="SemiBold" Foreground="#333"/>
                                                <TextBox Text="{Binding Email}"
                                                         IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}"
                                                         PlaceholderText="Enter email"
                                                         Padding="12"
                                                         Height="40"/>
                                            </StackPanel>
                                            
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Password" FontWeight="SemiBold" Foreground="#333"/>
                                                <TextBox Text="{Binding Password}"
                                                         IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}"
                                                         PasswordChar="*"
                                                         PlaceholderText="Enter password"
                                                         Padding="12"
                                                         Height="40"/>
                                            </StackPanel>

                                            <Border Height="1" Background="#E0E0E0" Margin="0,8,0,8"/>

                                            <TextBlock Text="Health Information"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="#2C3E50"/>

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Health Conditions" FontWeight="SemiBold" Foreground="#333"/>
                                                
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBox Grid.Column="0" 
                                                             Text="{Binding NewHealthCondition}"
                                                             IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}"
                                                             PlaceholderText="Add health condition"
                                                             Padding="12"
                                                             Height="40"/>
                                                    <Button Grid.Column="1" 
                                                            Content="+"
                                                            Command="{Binding AddHealthConditionCommand}"
                                                            IsVisible="{Binding IsEditing}"
                                                            Padding="12,6"
                                                            Background="#3498DB"
                                                            Foreground="White"
                                                            Cursor="Hand"/>
                                                </Grid>
                                                
                                                <ItemsControl ItemsSource="{Binding HealthConditions}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#F0F0F0" 
                                                                    CornerRadius="4" 
                                                                    Padding="8,4" 
                                                                    Margin="0,2">
                                                                <DockPanel>
                                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                                                    <Button DockPanel.Dock="Right"
                                                                            Content="X"
                                                                            Command="{Binding $parent[ItemsControl].DataContext.RemoveHealthConditionCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            IsVisible="{Binding $parent[ItemsControl].DataContext.IsEditing}"
                                                                            Background="Transparent"
                                                                            Foreground="#E74C3C"
                                                                            Cursor="Hand"
                                                                            Padding="8,0"/>
                                                                </DockPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel Spacing="4" Margin="0,8,0,0">
                                                <TextBlock Text="Disabilities" FontWeight="SemiBold" Foreground="#333"/>
                                                
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBox Grid.Column="0" 
                                                             Text="{Binding NewDisability}"
                                                             IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}"
                                                             PlaceholderText="Add disability"
                                                             Padding="12"
                                                             Height="40"/>
                                                    <Button Grid.Column="1" 
                                                            Content="+"
                                                            Command="{Binding AddDisabilityCommand}"
                                                            IsVisible="{Binding IsEditing}"
                                                            Padding="12,6"
                                                            Background="#3498DB"
                                                            Foreground="White"
                                                            Cursor="Hand"/>
                                                </Grid>
                                                
                                                <ItemsControl ItemsSource="{Binding Disabilities}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#F0F0F0" 
                                                                    CornerRadius="4" 
                                                                    Padding="8,4" 
                                                                    Margin="0,2">
                                                                <DockPanel>
                                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                                                    <Button DockPanel.Dock="Right"
                                                                            Content="X"
                                                                            Command="{Binding $parent[ItemsControl].DataContext.RemoveDisabilityCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            IsVisible="{Binding $parent[ItemsControl].DataContext.IsEditing}"
                                                                            Background="Transparent"
                                                                            Foreground="#E74C3C"
                                                                            Cursor="Hand"
                                                                            Padding="8,0"/>
                                                                </DockPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            
                                            <TextBlock Text="{Binding SaveMessage}"
                                                       Foreground="{Binding IsSaveSuccess, 
                                                           Converter={StaticResource BoolToColorConverter},
                                                           ConverterParameter='#27AE60|#E74C3C'}"
                                                       FontWeight="SemiBold"
                                                       IsVisible="{Binding SaveMessage, 
                                                           Converter={StaticResource StringIsNotNullOrEmpty}}"/>
                                            
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                                
                                                <Button Content="Edit Profile"
                                                        Command="{Binding ToggleEditCommand}"
                                                        IsVisible="{Binding IsEditing, 
                                                            Converter={StaticResource InvertedBoolConverter}}"
                                                        Background="#3498DB"
                                                        Foreground="White"
                                                        FontWeight="SemiBold"
                                                        Padding="24,10"
                                                        CornerRadius="6"
                                                        Cursor="Hand"/>
                                                
                                                <Button Content="Save Changes"
                                                        Command="{Binding SaveProfileCommand}"
                                                        IsVisible="{Binding IsEditing}"
                                                        Background="#27AE60"
                                                        Foreground="White"
                                                        FontWeight="SemiBold"
                                                        Padding="24,10"
                                                        CornerRadius="6"
                                                        Cursor="Hand"/>
                                                
                                                <Button Content="Cancel"
                                                        Command="{Binding ToggleEditCommand}"
                                                        IsVisible="{Binding IsEditing}"
                                                        Background="#95A5A6"
                                                        Foreground="White"
                                                        FontWeight="SemiBold"
                                                        Padding="24,10"
                                                        CornerRadius="6"
                                                        Cursor="Hand"/>
                                                
                                            </StackPanel>
                                            
                                        </StackPanel>
                                    </Grid>
                                    
                                </StackPanel>
                                
                            </DataTemplate>
                        </ContentControl.DataTemplates>
                    </ContentControl>
                    
                </ScrollViewer>
            </TabItem>

        </TabControl>

    </Grid>

</Window>